# Local, gitignored mise config - copy to `.mise.local.toml` and fill in
# your own values. Used by `mise run run-linux` / `mise run run-android`
# (see mise.toml) to forward the Google Drive sync OAuth config as
# --dart-define. See README.md's "Google Drive sync configuration" for
# where these values come from - omit any of them to run/build with Drive
# sync disabled.
[env]
DRIVE_DESKTOP_CLIENT_ID = "your-desktop-client-id.apps.googleusercontent.com"
DRIVE_DESKTOP_CLIENT_SECRET = "your-desktop-client-secret"
DRIVE_ANDROID_SERVER_CLIENT_ID = "your-android-server-client-id.apps.googleusercontent.com"
